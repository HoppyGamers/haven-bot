# =============================================================================
# Haven Bot Configuration
# Copy this file to .env and fill in your values
# =============================================================================

# -------------------------------------------------------
# Haven Server
# -------------------------------------------------------

# URL of your Haven server
HAVEN_SERVER_URL=https://your-haven-server.com/

# Bot display name (shown in Haven chat)
BOT_NAME=HavenBot

# Bot avatar URL (optional)
BOT_AVATAR_URL=

# -------------------------------------------------------
# Webhook & Channel Setup
# -------------------------------------------------------

# Bootstrap channel — the first channel the bot connects to.
# Create a webhook in Haven: Settings → Server Admin Settings → Bots
# Format: ChannelName:ChannelCode:Token
#   ChannelName — friendly name shown in bot logs
#   ChannelCode — 8-character join code shown in the Haven channel header
#   Token       — 64-character webhook token from Haven Bot Management
#
# This is the ONLY channel you need to configure here.
# Additional channels can be added at runtime without restarting:
#   /addchannel <name> <code> <token>
#
# Note: Set ALL bot callback URLs in Haven to the same CALLBACK_URL.
# Haven routes all slash commands through the primary bot's callback URL.
WEBHOOK_TOKENS=General:a9b20e93:your_64_character_token_here

# Public URL for receiving slash command callbacks from Haven
# Must be reachable by your Haven server (use your public IP or domain)
CALLBACK_URL=http://your-public-ip:3000/

# Secret for HMAC verification of incoming callbacks (recommended)
# Any random string works — used to verify requests are from your Haven server
CALLBACK_SECRET=your-callback-secret-here

# Port for the callback server (default: 3002)
# Haven uses 3000 and 3001 internally — use 3002 to avoid conflicts
PORT=3002

# -------------------------------------------------------
# Bot Settings
# -------------------------------------------------------

# IANA timezone name used for event display, notifications, and digests
# Examples: America/New_York, America/Chicago, America/Los_Angeles, Europe/London
TIMEZONE=UTC

# Path to the SQLite database file
# For Docker: set to a path inside your mounted data volume (e.g. /data/haven-bot.db)
# For local dev: leave blank to use the project root
DB_PATH=

# Enable verbose debug logging
DEBUG=false

# -------------------------------------------------------
# Bot Greeting
# -------------------------------------------------------

# Message posted to each channel when the bot starts (leave blank to disable)
BOT_GREETING=

# One-time greeting posted the first time the bot connects to a channel
BOT_FIRST_TIME_GREETING=

# -------------------------------------------------------
# Auto-Delete Timers
# -------------------------------------------------------
# Automatically delete bot responses after N seconds (0 = never delete)
#
# HELP_DELETE_SECONDS  — /help responses
# ADMIN_DELETE_SECONDS — admin command responses (ban, kick, rss add, calendar add, etc.)
# USER_DELETE_SECONDS  — user command responses (profile, leaderboard, stats, etc.)

HELP_DELETE_SECONDS=0
ADMIN_DELETE_SECONDS=0
USER_DELETE_SECONDS=0

# -------------------------------------------------------
# XP & Leveling
# -------------------------------------------------------

# Cooldown between XP awards per user in milliseconds (default: 5000 = 5 seconds)
# Prevents spam-clicking commands to farm XP
XP_COOLDOWN_MS=5000

# -------------------------------------------------------
# Custom Commands
# -------------------------------------------------------

# Who can create, edit, and delete custom commands
# Options: admin (default), everyone
CUSTOM_COMMANDS_PERMISSION=admin

# -------------------------------------------------------
# Soundboard
# -------------------------------------------------------

# Comma-separated list of sound names available on your Haven server
# Haven's API does not expose available sounds to bots, so these must be
# configured manually. Find names in Haven Settings → Soundboard.
# Example: SOUNDS=AOL - You've Got Mail,Airhorn,Sad Trombone
SOUNDS=

# -------------------------------------------------------
# RSS
# -------------------------------------------------------

# How often to check RSS feeds for new items (minutes, default: 15)
RSS_CHECK_INTERVAL=15

# Max new items to post per feed per check cycle (prevents flooding, default: 5)
RSS_MAX_ITEMS=5

# -------------------------------------------------------
# Web Dashboard (optional)
# -------------------------------------------------------

# Secret key for signing dashboard session tokens.
# Generate with: openssl rand -base64 48
# Leave blank to disable the dashboard entirely.
#
# Security note: haven-bot.db contains webhook tokens for runtime-added channels.
# Restrict file permissions: chmod 600 haven-bot.db haven-agent.db
DASHBOARD_SECRET=

# Port for the web dashboard (default: 3003)
# Haven uses ports 3000 and 3001 internally — avoid those.
DASHBOARD_PORT=3003

# -------------------------------------------------------
# AI Agent (optional — bot works fully without these)
# -------------------------------------------------------

# Set to true to enable the AI agent
AGENT_ENABLED=false

# Agent display name — used in responses, /help, and briefings
AGENT_NAME=Bob

# Slash command that triggers the agent (e.g. /bob)
# Defaults to lowercase of AGENT_NAME if not set
AGENT_COMMAND=bob

# Global system prompt — defines the agent's persona across all channels
# Per-channel overrides can be set at runtime via /bob config set-prompt
AGENT_SYSTEM_PROMPT=You are Bob, a helpful AI assistant for the Haven voice chat server. Always respond in English. Be concise and friendly.

# Participation mode: command | mention | passive | active
# command = slash command only (safest, recommended starting point)
# mention = responds when full agent name appears in a message
# passive = monitors messages, responds to questions it can answer
# active  = participates freely (use with caution, scope to specific channels)
AGENT_MODE=command

# Seconds between unprompted responses in passive/active mode
AGENT_COOLDOWN=30

# Comma-separated list of channel names to limit agent to (blank = all channels)
AGENT_CHANNELS=

# Minimum confidence threshold for passive mode (0.0 - 1.0)
AGENT_CONFIDENCE=0.8

# Number of messages to keep in conversation history per channel
AGENT_HISTORY_SIZE=20

# Path to the agent database (defaults to same directory as DB_PATH)
# For Docker: set to a path inside your mounted data volume (e.g. /data/haven-agent.db)
# AGENT_DB_PATH=/data/haven-agent.db

# -------------------------------------------------------
# Ollama (required for AI agent)
# -------------------------------------------------------

# URL of your Ollama instance
OLLAMA_URL=http://localhost:11434

# Model to use — qwen2.5:7b for getting started, qwen2.5:14b for better quality
# The 14b model has significantly better tool calling and instruction following
OLLAMA_MODEL=qwen2.5:7b

# -------------------------------------------------------
# SearXNG (optional — enables web search for AI agent)
# -------------------------------------------------------

# URL of your SearXNG instance — leave blank to disable web search
# When set, the agent searches for current info before answering questions
SEARXNG_URL=
