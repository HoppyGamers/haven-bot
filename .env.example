# Haven Bot Configuration
# Copy this file to .env and fill in your values
# Run: npm run setup   (interactive wizard)
# Or:  manually fill in the values below

# -------------------------------------------------------
# Required
# -------------------------------------------------------

# Your Haven server URL (no trailing slash)
HAVEN_SERVER_URL=https://your-server.com

# Single channel setup — use WEBHOOK_TOKEN
WEBHOOK_TOKEN=your_64_character_webhook_token_here

# Multi-channel setup — use WEBHOOK_TOKENS instead (overrides WEBHOOK_TOKEN)
# Create one webhook per channel in Haven: Settings → Server Admin Settings → Bots
# Important: set ALL bot callback URLs to match the General bot's CALLBACK_URL
# Haven routes all slash commands through the primary bot's callback URL
#
# Format: ChannelName:ChannelCode:Token (comma separated, no spaces)
#   ChannelName — friendly name shown in bot logs
#   ChannelCode — 8-character join code shown in the Haven channel header
#   Token       — 64-character webhook token from Haven Bot Management
WEBHOOK_TOKENS=General:a9b20e93:your_general_token_here,Gaming:87057084:your_gaming_token_here,Events:76fe37ad:your_events_token_here

# -------------------------------------------------------
# Callback Server (required for slash commands)
# -------------------------------------------------------

# Public URL Haven will POST slash command events to
# Must be reachable from your Haven server
CALLBACK_URL=https://your-public-ip:3001

# Secret for HMAC signature verification (any random string)
CALLBACK_SECRET=your_callback_secret_here

# Port the callback server listens on
PORT=3000

# -------------------------------------------------------
# Bot Identity (optional)
# -------------------------------------------------------

# Display name for bot messages
BOT_NAME=HavenBot

# Avatar URL for bot messages
BOT_AVATAR_URL=

# -------------------------------------------------------
# Database
# -------------------------------------------------------

# Path to the SQLite database file.
# Default: haven-bot.db in the project root (local development)
# Docker: set to /data/haven-bot.db and mount a volume at /data
DB_PATH=

# -------------------------------------------------------
# RSS Reader
# -------------------------------------------------------

# How often to check RSS feeds for new items (minutes, default: 15)
RSS_CHECK_INTERVAL=15

# Max new items to post per feed per check (prevents flooding, default: 5)
RSS_MAX_ITEMS=5

# -------------------------------------------------------
# Calendar
# -------------------------------------------------------

# IANA timezone name for event display (default: UTC)
# Examples: America/New_York, America/Chicago, America/Los_Angeles, Europe/London
TIMEZONE=UTC

# -------------------------------------------------------
# Bot Behavior
# -------------------------------------------------------

# Message shown when bot comes online (supports markdown)
# Default: "👋 Haven Bot is online! Type /help to see what I can do."
BOT_GREETING=

# First-time user greeting (shown on first command, supports {user} variable)
# Default: "👋 Welcome {user}! Type /help to see what I can do."
BOT_FIRST_TIME_GREETING=

# XP spam cooldown in milliseconds (default: 5000 = 5 seconds)
XP_COOLDOWN_MS=5000

# -------------------------------------------------------
# Custom Commands
# -------------------------------------------------------

# Who can create/edit/delete custom commands
# Options: admin (default), everyone
CUSTOM_COMMANDS_PERMISSION=admin

# -------------------------------------------------------
# Soundboard
# -------------------------------------------------------

# Comma-separated list of sound names available on your Haven server
# Find names in Haven Settings → Soundboard
# Example: SOUNDS=AOL - You've Got Mail,Airhorn,Sad Trombone
SOUNDS=

# -------------------------------------------------------
# Help Command
# -------------------------------------------------------

# Seconds before /help message is automatically deleted (0 = never delete)
HELP_DELETE_SECONDS=0

# -------------------------------------------------------
# Debug
# -------------------------------------------------------

# Set to true to enable verbose logging
DEBUG=false

# -------------------------------------------------------
# AI Agent (optional — bot works without these)
# -------------------------------------------------------

# Set to true to enable the AI agent
AGENT_ENABLED=false

# Agent display name — used in responses and /help
AGENT_NAME=Bob

# Slash command that triggers the agent (e.g. /bob)
# Defaults to lowercase of AGENT_NAME if not set
AGENT_COMMAND=bob

# Global system prompt — defines who the agent is across all channels
# Per-channel overrides can be set at runtime via /bob config set-prompt
AGENT_SYSTEM_PROMPT=You are Bob, a helpful AI assistant for the Haven voice chat server. Be concise and friendly.

# Participation mode: command | mention | passive | active
# command = slash command only (recommended starting point)
# mention = responds when name appears in messages
# passive = monitors messages, responds when relevant
# active  = participates freely (use with caution, scope to specific channels)
AGENT_MODE=command

# Seconds between unprompted responses in passive/active mode
AGENT_COOLDOWN=30

# Comma-separated list of channel names to limit agent to (blank = all channels)
AGENT_CHANNELS=

# Minimum confidence threshold for passive mode responses (0.0 - 1.0)
AGENT_CONFIDENCE=0.8

# Number of messages to keep in conversation history per channel
AGENT_HISTORY_SIZE=20

# Path to the agent database (defaults to same folder as DB_PATH)
# AGENT_DB_PATH=/data/haven-agent.db

# -------------------------------------------------------
# Ollama (required for AI agent)
# -------------------------------------------------------

# URL of your Ollama instance
OLLAMA_URL=http://localhost:11434

# Model to use — qwen2.5:7b recommended for getting started
# Upgrade to qwen2.5:14b for better quality once pipeline is working
OLLAMA_MODEL=qwen2.5:7b

# -------------------------------------------------------
# SearXNG (optional — enables web search for AI agent)
# -------------------------------------------------------

# URL of your SearXNG instance — leave blank to disable web search
# When set, the agent will search for current info before answering questions
SEARXNG_URL=
