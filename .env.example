# Haven Bot Configuration
# Copy this file to .env and fill in your values
# Run: npm run setup   (interactive wizard)
# Or:  manually fill in the values below

# -------------------------------------------------------
# Required
# -------------------------------------------------------

# Your Haven server URL (no trailing slash)
HAVEN_SERVER_URL=https://your-server.com

# Single channel setup — use WEBHOOK_TOKEN
WEBHOOK_TOKEN=your_64_character_webhook_token_here

# Multi-channel setup — use WEBHOOK_TOKENS instead (overrides WEBHOOK_TOKEN)
# Create one webhook per channel in Haven: Settings → Server Admin Settings → Bots
# All webhooks should point to the same CALLBACK_URL
# Format: token:ChannelName,token:ChannelName,...
WEBHOOK_TOKENS=token1:General,token2:Gaming,token3:Events

# -------------------------------------------------------
# Callback Server (required for slash commands)
# -------------------------------------------------------

# Public URL Haven will POST slash command events to
# Must be reachable from your Haven server
CALLBACK_URL=https://your-public-ip:3001

# Secret for HMAC signature verification (any random string)
CALLBACK_SECRET=your_callback_secret_here

# Port the callback server listens on
PORT=3000

# -------------------------------------------------------
# Bot Identity (optional)
# -------------------------------------------------------

# Display name for bot messages
BOT_NAME=HavenBot

# Avatar URL for bot messages
BOT_AVATAR_URL=

# -------------------------------------------------------
# Database
# -------------------------------------------------------

# Path to the SQLite database file.
# Default: haven-bot.db in the project root (local development)
# Docker: set to /data/haven-bot.db and mount a volume at /data
DB_PATH=

# -------------------------------------------------------
# RSS Reader
# -------------------------------------------------------

# How often to check RSS feeds for new items (minutes, default: 15)
RSS_CHECK_INTERVAL=15

# Max new items to post per feed per check (prevents flooding, default: 5)
RSS_MAX_ITEMS=5

# -------------------------------------------------------
# Calendar
# -------------------------------------------------------

# IANA timezone name for event display (default: UTC)
# Examples: America/New_York, America/Chicago, America/Los_Angeles, Europe/London
TIMEZONE=UTC

# -------------------------------------------------------
# Bot Behavior
# -------------------------------------------------------

# Message shown when bot comes online (supports markdown)
# Default: "👋 Haven Bot is online! Type /help to see what I can do."
BOT_GREETING=

# First-time user greeting (shown on first command, supports {user} variable)
# Default: "👋 Welcome {user}! Type /help to see what I can do."
BOT_FIRST_TIME_GREETING=

# XP spam cooldown in milliseconds (default: 5000 = 5 seconds)
XP_COOLDOWN_MS=5000

# -------------------------------------------------------
# Custom Commands
# -------------------------------------------------------

# Who can create/edit/delete custom commands
# Options: admin (default), everyone
CUSTOM_COMMANDS_PERMISSION=admin

# -------------------------------------------------------
# Soundboard
# -------------------------------------------------------

# Comma-separated list of sound names available on your Haven server
# Find names in Haven Settings → Soundboard
# Example: SOUNDS=AOL - You've Got Mail,Airhorn,Sad Trombone
SOUNDS=

# -------------------------------------------------------
# Debug
# -------------------------------------------------------

# Set to true to enable verbose logging
DEBUG=false
